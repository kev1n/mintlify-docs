{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AnyAPI",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#e8743c",
    "light": "#e8743c",
    "dark": "#c85a1c"
  },
  "background": {
    "color": {
      "light": "#fbfbfa",
      "dark": "#0b0b0d"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart",
          "mcp"
        ]
      },
      {
        "group": "API Reference",
        "openapi": "openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "href": "https://getanyapi.com",
          "icon": "house"
        },
        {
          "anchor": "Dashboard",
          "href": "https://app.getanyapi.com",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@getanyapi.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.getanyapi.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "download-spec",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/anyapi",
      "github": "https://github.com/kev1n/mintlify-docs"
    }
  }
}
